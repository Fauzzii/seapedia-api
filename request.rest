# ==========================================
# USERS
# ==========================================

### Get All Users - Khusus ADMIN
GET http://localhost:5000/users

### Get User By ID - Butuh Login
GET http://localhost:5000/users/1

### Register User (Public)
POST http://localhost:5000/users
Content-Type: application/json

{
    "full_name": "John Doe",
    "email": "john.doe@example.com",
    "password": "Password123"
}
# Note: Role otomatis diset "USER" saat register

### Update User - Butuh Login
# User biasa hanya bisa update profil sendiri (tanpa role)
# Admin bisa update siapa saja dan merubah role
PATCH http://localhost:5000/users/1
Content-Type: application/json

{
    "full_name": "Fauzi",
    "email": "fauzi@example.com",
    "role": "ADMIN" 
}

### Delete User - Khusus ADMIN
DELETE http://localhost:5000/users/1